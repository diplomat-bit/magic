{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@components/*": ["./components/*"],
      "@api/*": ["./api/*"]
    }
  },
  "include": [
    "src",
    "components",
    "api",
    "types",
    "utils",
    "constants.tsx",
    "hooks"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/* (?).tsx",
    "**/* (??).tsx",
    "**/* (*).tsx",
    "**/*.md",
    "**/*.md.md",
    "build.log",
    "lint-results",
    "schema.prisma.txt",
    "tsconfig.node.json.md",
    "types.ts.md",
    "vite.config.ts.md",
    "README.md.md",
    "./App.tsx",
    "./app.tsx",
    "./components/App.tsx",
    "./index.tsx",
    "./index.js",
    "./server.js",
    "./server/index.js",
    "./o.sh",
    "./ok.sh",
    "./okk.sh",
    "./manifest.json",
    "./metadata.json",
    "./microfrontends.json",
    "./package-lock.json",
    "./schema.prisma",
    "./tailwind.config.js",
    "./valid_tsx"
  ]
}